const API_BASE = window.location.hostname === 'localhost'
  ? 'http://localhost:3000/api'
  : 'https://vivaris-care-production.up.railway.app/api';

const token = localStorage.getItem('token');
const user = JSON.parse(localStorage.getItem('user') || '{}');

if (!token) {
  alert('Não autenticado!');
  window.location.href = '/';
}

// SUBMIT FORM
function submitForm() {
  console.log('📝 Coletando dados do formulário...');
  
  const form = document.getElementById('residentForm');
  if (!form) {
    alert('Formulário não encontrado!');
    return;
  }

  const formData = new FormData(form);
  const data = Object.fromEntries(formData);

  console.log('📤 Dados coletados:', data);

  // Validar obrigatórios
  if (!data.full_name || !data.birth_date) {
    alert('❌ Nome e Data de Nascimento são obrigatórios!');
    return;
  }

  // Enviar pro servidor
  fetch(`${API_BASE}/residents`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${token}`
    },
    body: JSON.stringify(data)
  })
  .then(res => {
    console.log('📬 Response status:', res.status);
    return res.json().then(json => ({ status: res.status, json }));
  })
  .then(({ status, json }) => {
    console.log('📥 Response:', json);

    if (status === 201) {
      alert(`✅ RESIDENTE SALVO!\n\nNome: ${data.full_name}\nID: ${json.resident_id}`);
      window.location.href = '/html/comercial-dashboard.html';
    } else {
      alert(`❌ ERRO: ${json.error}\n\nDetalhes: ${json.details}`);
    }
  })
  .catch(error => {
    console.error('🔴 Erro:', error);
    alert(`❌ ERRO NA CONEXÃO:\n\n${error.message}`);
  });
}

// VOLTAR
function goBack() {
  window.history.back();
}

// CALCULAR IDADE
document.addEventListener('DOMContentLoaded', () => {
  const birthDateInput = document.querySelector('[name="birth_date"]');
  if (birthDateInput) {
    birthDateInput.addEventListener('change', () => {
      const birthDate = new Date(birthDateInput.value);
      const today = new Date();
      let age = today.getFullYear() - birthDate.getFullYear();
      const month = today.getMonth() - birthDate.getMonth();
      if (month < 0 || (month === 0 && today.getDate() < birthDate.getDate())) {
        age--;
      }
      const ageInput = document.getElementById('age');
      if (ageInput) ageInput.value = age;
    });
  }

  // Setup tabs
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const tabNum = btn.dataset.tab;
      showTab(tabNum);
    });
  });

  showTab(1);
});

// TAB NAVIGATION
let currentTab = 1;

function showTab(n) {
  currentTab = parseInt(n);
  
  document.querySelectorAll('.tab-content').forEach(tab => {
    tab.classList.remove('active');
  });
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.classList.remove('active');
  });

  const activeTab = document.querySelector(`[data-tab="${n}"]`);
  if (activeTab && activeTab.classList.contains('tab-content')) {
    activeTab.classList.add('active');
  }

  const activeBtn = document.querySelector(`.tab-btn[data-tab="${n}"]`);
  if (activeBtn) {
    activeBtn.classList.add('active');
  }

  updateProgress();
  window.scrollTo(0, 0);
}

function nextTab() {
  if (currentTab < 17) {
    showTab(currentTab + 1);
  }
}

function previousTab() {
  if (currentTab > 1) {
    showTab(currentTab - 1);
  }
}

function updateProgress() {
  const progress = (currentTab / 17) * 100;
  const bar = document.getElementById('progressBar');
  if (bar) {
    bar.style.width = progress + '%';
  }
}

console.log('✅ resident-form.js carregado');
